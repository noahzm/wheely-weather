{
  "expo": {
    "name": "Wheely Weather",
    "slug": "wheely-weather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wheelyweather",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.wheelyweather",
      "appleTeamId": "Y2S6C64A97",
      "icon": "./assets/WheelyWeather.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.weatherkit": true
      }
    },
    "android": {
      "package": "app.wheelyweather",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://wheelyweather.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Ronzino-Regular",
                "fontDefinitions": [
                  {
                    "path": "assets/fonts/Ronzino-Regular.otf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "Ronzino-Medium",
                "fontDefinitions": [
                  {
                    "path": "assets/fonts/Ronzino-Medium.otf",
                    "weight": 500
                  }
                ]
              },
              {
                "fontFamily": "Ronzino-Bold",
                "fontDefinitions": [
                  {
                    "path": "assets/fonts/Ronzino-Bold.otf",
                    "weight": 700
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "assets/fonts/Ronzino-Regular.otf",
              "assets/fonts/Ronzino-Medium.otf",
              "assets/fonts/Ronzino-Bold.otf",
              "assets/fonts/Ronzino-Oblique.otf",
              "assets/fonts/Ronzino-MediumOblique.otf",
              "assets/fonts/Ronzino-BoldOblique.otf"
            ]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Wheely Weather to use your location for local cycling forecasts.",
          "locationAlwaysAndWhenInUsePermission": false,
          "locationAlwaysPermission": false,
          "motionUsagePermission": "Wheely Weather does not use motion or fitness data. This permission string is required by a location library dependency."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "organization": "noah-michaels",
          "project": "wheely-weather",
          "disableAutoUpload": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef6ed602-3db3-4a98-8498-52ad5442e138"
      }
    },
    "owner": "noahzm"
  }
}
