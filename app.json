{
  "expo": {
    "name": "Wheely Weather",
    "slug": "wheely-weather",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wheelyweather",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "app.wheelyweather",
      "icon": "./assets/WheelyWeather.icon",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.wheelyweather",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://wheelyweather.app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-localization",
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "National Park",
                "fontDefinitions": [
                  {
                    "path": "node_modules/@expo-google-fonts/national-park/400Regular/NationalPark_400Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "node_modules/@expo-google-fonts/national-park/700Bold/NationalPark_700Bold.ttf",
                    "weight": 700
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "node_modules/@expo-google-fonts/national-park/400Regular/NationalPark_400Regular.ttf",
              "node_modules/@expo-google-fonts/national-park/700Bold/NationalPark_700Bold.ttf"
            ]
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Wheely Weather to use your location for local cycling forecasts."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef6ed602-3db3-4a98-8498-52ad5442e138"
      }
    },
    "owner": "noahzm"
  }
}
