# Copy to .env and fill in for local dev. For EAS builds, set the same name
# as an EAS environment variable instead (eas env:create) so it's available
# at build time.

# Sentry crash/error reporting (src/services/telemetry.ts). Leave unset to
# disable — the app runs fine without it, just with no crash visibility.
EXPO_PUBLIC_SENTRY_DSN=

# Native iOS/Android builds also run the Sentry Xcode/Gradle build phases,
# which try to upload source maps and debug symbols via sentry-cli. Without
# a Sentry org/project/auth token configured, that upload fails and aborts
# the build. SENTRY_DISABLE_AUTO_UPLOAD must be a real env var (set it here,
# in .env, for local dev — an EAS env var for cloud builds) to skip it;
# sentry-xcode.sh only checks the process environment, so setting it in
# .env.sentry-build-plugin alone has no effect on this switch.
SENTRY_DISABLE_AUTO_UPLOAD=

# A root-level .env.sentry-build-plugin file (gitignored, not this one) is
# read by sentry-cli itself, separately, for SENTRY_ORG / SENTRY_PROJECT /
# SENTRY_AUTH_TOKEN — only needed if you actually want symbols uploaded.
