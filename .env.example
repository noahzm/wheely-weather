# Sentry crash/error reporting (src/services/telemetry.ts). Leave
# EXPO_PUBLIC_SENTRY_DSN unset to disable runtime reporting; the app
# runs fine without it. Set the real value in your gitignored .env.
EXPO_PUBLIC_SENTRY_DSN=

# Source-map uploads are disabled via disableAutoUpload: true in the
# @sentry/react-native/expo plugin config (app.json), so builds don't
# require SENTRY_AUTH_TOKEN.
