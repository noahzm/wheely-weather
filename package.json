{
  "name": "wheely-weather",
  "main": "index.ts",
  "version": "1.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/slider": "5.2.0",
    "@sentry/react-native": "~7.11.0",
    "expo": "~57.0.6",
    "expo-constants": "~57.0.2",
    "expo-dev-client": "~57.0.6",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-localization": "~57.0.1",
    "expo-location": "~57.0.4",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "lucide-react-native": "^1.24.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-ondevice-actions": "^10.4.7",
    "@storybook/addon-ondevice-controls": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-native": "^10.4.7",
    "@storybook/react-native-ui-lite": "^10.4.7",
    "@storybook/react-native-web-vite": "^10.5.0",
    "@types/react": "~19.2.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "babel-loader": "^8.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^60.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "serve": "^14.2.6",
    "storybook": "^10.4.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "typescript": "$typescript"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios",
    "ios:install": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo run:ios --no-bundler",
    "ios:start": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo start --dev-client --ios",
    "ios:start:localhost": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo start --dev-client --ios --host localhost",
    "ios:start:tunnel": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo start --dev-client --ios --host tunnel",
    "ios:prebuild": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo prebuild --platform ios",
    "ios:clean": "cross-env SENTRY_DISABLE_AUTO_UPLOAD=true expo prebuild --clean --platform ios && npm run ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "deploy:web": "npm run build:web && wrangler deploy",
    "lint": "expo lint -- --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --project unit",
    "test:e2e": "playwright test",
    "test:e2e:app": "playwright test --config playwright.app.config.ts",
    "storybook:ios": "cross-env STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --ios",
    "storybook:android": "cross-env STORYBOOK_ENABLED=true EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --android",
    "storybook:web": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "eas:build:ios-dev": "eas build --platform ios --profile development",
    "eas:build:ios-prod": "eas build --platform ios --profile production",
    "eas:build:android-dev": "eas build --platform android --profile development",
    "eas:build:android-prod": "eas build --platform android --profile production"
  },
  "private": true
}
